{
  "name": "auto-apply-chrome-extension",
  "version": "1.0.0",
  "description": "A Chrome Extension (Manifest V3) that automatically fills LinkedIn Easy Apply job applications using a stored user profile, Gemini AI for intelligent field filling, a persistent question bank, and a Side Panel UI.",
  "scripts": {
    "build": "webpack --config webpack.config.js --mode production",
    "dev": "webpack --config webpack.config.js --mode development --watch"
  },
  "dependencies": {
    "jspdf": "^4.2.0",
    "lucide-react": "^0.575.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@babel/core": "^7.22.10",
    "@babel/preset-env": "^7.22.10",
    "@babel/preset-react": "^7.22.5",
    "autoprefixer": "^10.4.14",
    "babel-loader": "^9.1.3",
    "copy-webpack-plugin": "^11.0.0",
    "css-loader": "^6.8.1",
    "html-webpack-plugin": "^5.5.3",
    "mini-css-extract-plugin": "^2.10.0",
    "postcss": "^8.4.27",
    "postcss-loader": "^8.2.1",
    "style-loader": "^3.3.3",
    "tailwindcss": "^3.3.3",
    "webpack": "^5.88.2",
    "webpack-cli": "^5.1.4"
  }
